{
  "name": "Flexoki Light",
  "author": "Steph Ango (Flexoki palette); ported by Haoxin Yang",
  "dark": false,
  "editorScheme": "/themes/flexoki-light.xml",
  "colors": {
    "paper": "#FFFCF0",
    "bg2": "#F2F0E5",
    "ui": "#E6E4D9",
    "ui2": "#DAD8CE",
    "ui3": "#CECDC3",
    "tx3": "#B7B5AC",
    "tx2": "#6F6E69",
    "tx": "#100F0F",
    "red": "#AF3029",
    "orange": "#BC5215",
    "green": "#66800B",
    "blue": "#205EA6",
    "magenta": "#A02F6F"
  },
  "ui": {
    "*": {
      "background": "paper",
      "foreground": "tx",
      "infoForeground": "tx2",
      "disabledForeground": "tx3",
      "disabledBackground": "bg2",
      "selectionBackground": "ui3",
      "selectionForeground": "tx",
      "selectionInactiveBackground": "ui2",
      "selectionInactiveForeground": "tx",
      "borderColor": "ui",
      "separatorColor": "ui2",
      "acceleratorForeground": "tx2",
      "focusColor": "blue",
      "focusedBorderColor": "blue"
    },
    "Panel.background": "paper",
    "Popup.background": "paper",
    "Tree.background": "paper",
    "Tree.selectionBackground": "ui3",
    "Tree.selectionInactiveBackground": "ui2",
    "List.background": "paper",
    "List.selectionBackground": "ui3",
    "List.selectionForeground": "tx",
    "Table.background": "paper",
    "Table.selectionBackground": "ui3",
    "MainToolbar.background": "bg2",
    "ToolWindow.Header.background": "bg2",
    "ToolWindow.Button.selectedBackground": "ui",
    "DefaultTabs.background": "bg2",
    "EditorTabs.background": "bg2",
    "EditorTabs.underlinedTabBackground": "paper",
    "EditorTabs.underlineColor": "blue",
    "StatusBar.background": "bg2",
    "Button.startBackground": "bg2",
    "Button.endBackground": "bg2",
    "Button.foreground": "tx",
    "Button.default.startBackground": "blue",
    "Button.default.endBackground": "blue",
    "Button.default.foreground": "paper",
    "Link.activeForeground": "blue",
    "Component.focusColor": "blue",
    "ProgressBar.progressColor": "blue",
    "Notification.background": "bg2",
    "ScrollBar.thumbColor": "ui2"
  },
  "icons": {
    "ColorPalette": {
      "Actions.Blue": "#205EA6",
      "Actions.Green": "#66800B",
      "Actions.Red": "#AF3029",
      "Actions.Yellow": "#AD8301",
      "Actions.Grey": "#6F6E69"
    }
  }
}
